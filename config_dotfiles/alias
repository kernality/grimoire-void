alias ..="cd .."
alias ...="cd ../../"
alias ls="eza --icons"
alias la="ls -la"
alias tree="eza --tree"
alias ntree="eza --tree -I 'node_modules|dist'"
alias vv="nvim"
alias xx="exit"
alias lg="lazygit"
alias ins='nvim $(fzf -m --preview="bat --theme=gruvbox-dark --color=always {}")'
alias bt="blueman-manager"
alias wm="wiremix"
alias lf='cd "$(command lf -print-last-dir "$@")"'
alias xi="sudo xbps-install"
alias up="sudo xbps-install -Suy"
alias ref="sudo xbps-install -S"
alias search="xbps-query -Rs"
alias xr="sudo xbps-remove"
alias xclean="sudo xbps-remove -Oo"
alias list="xbps-query -l"
alias pkgs="xbps-query -l | wc -l"
alias mirror="sudo xmirror"
alias battery="acpi -b"
alias power="sudo tlp-stat -s"
alias tnew="tmux new -s"
alias tls="tmux ls"
alias trename="tmux rename-session -t"
alias ta="tmux a -t"
